{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "strict": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "paths": {
      "@backend/*": ["./src/*"],
      "@api/*": ["../../packages/api/src/*"],
      "@root/*": ["../../*"],
      "@gen/*": ["../../packages/api/src/generated/*"]
    },
    "composite": true
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../packages/api" }
  ],
  "exclude": ["node_modules"]
}
